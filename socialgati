/* ===== SETTINGS ===== */
.settings-section { padding: 20px; }
.settings-group { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; margin-bottom: 20px; }
.settings-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 18px;
