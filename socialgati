<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>NewsTally — Read. Repost. Connect.</title>
<meta name="description" content="NewsTally — Your professional news and community platform."/>
<meta name="theme-color" content="#0a0a0f"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
<style>
/* ===== CSS VARIABLES & RESET ===== */
:root {
  --ink: #0a0a14;
  --ink-2: #1a1a35;
  --paper: #f4f6fb;
  --paper-2: #e8ecf5;
  --accent: #0077ff;
  --accent-2: #0095f6;
  --accent-glow: rgba(0,119,255,0.18);
  --gold: #f4a261;
  --blue: #023e8a;
  --blue-soft: #0077b6;
  --muted: #6b7280;
  --border: #d1cec5;
  --card-bg: #ffffff;
  --shadow-sm: 0 1px 3px rgba(10,10,15,0.08);
  --shadow-md: 0 4px 16px rgba(10,10,15,0.12);
  --shadow-lg: 0 12px 40px rgba(10,10,15,0.18);
  --r: 12px;
  --r-sm: 6px;
  --transition: 0.22s cubic-bezier(.4,0,.2,1);
  --font-display: 'Playfair Display', Georgia, serif;
  --font-body: 'DM Sans', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
}
html.dark {
  --ink: #f0ede8;
  --ink-2: #c8c5be;
  --paper: #0d0d12;
  --paper-2: #161620;
  --card-bg: #1a1a25;
  --border: #2a2a38;
  --muted: #6b7280;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.4);
  --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.6);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--paper);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
  overscroll-behavior-y: none;
  transition: background var(--transition), color var(--transition);
  min-height: 100dvh;
  padding-bottom: 64px;
}
@media(min-width:768px) { body { padding-bottom: 0; } }
a { color: inherit; text-decoration: none; }
button { font-family: var(--font-body); cursor: pointer; border: none; background: none; color: inherit; }
img { max-width: 100%; display: block; }
input, textarea { font-family: var(--font-body); }

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

/* ===== HEADER ===== */
header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: 56px;
  background: rgba(248,246,240,0.92);
  backdrop-filter: blur(16px) saturate(180%);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 20px;
  transition: background var(--transition);
}
html.dark header { background: rgba(13,13,18,0.92); }
.logo {
  display: flex; align-items: center; gap: 10px; cursor: pointer;
  user-select: none;
}
.logo-mark {
  width: 34px; height: 34px;
  background: linear-gradient(135deg, #0077ff, #0040dd);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-weight: 900; font-size: 18px;
  color: white;
  box-shadow: 0 2px 8px rgba(200,16,46,0.35);
  transition: transform 0.2s;
}
.logo-mark:hover { transform: rotate(-5deg) scale(1.05); }
.logo-text {
  font-family: var(--font-display);
  font-size: 20px; font-weight: 700;
  letter-spacing: -0.5px;
  display: none;
}
@media(min-width:640px) { .logo-text { display: block; } }
.header-nav {
  display: none; gap: 28px; align-items: center;
}
@media(min-width:768px) { .header-nav { display: flex; } }
.header-nav button {
  font-size: 14px; font-weight: 600;
  color: var(--muted);
  padding: 6px 0;
  border-bottom: 2px solid transparent;
  transition: color var(--transition), border-color var(--transition);
  letter-spacing: 0.01em;
}
.header-nav button:hover { color: var(--ink); }
.header-nav button.active-nav { color: var(--accent); border-bottom-color: var(--accent); }
.header-actions { display: flex; align-items: center; gap: 10px; }
.btn-signin {
  background: linear-gradient(135deg, #0077ff, #0040dd);
  color: white;
  padding: 7px 18px;
  border-radius: 99px;
  font-size: 13px; font-weight: 700;
  transition: all var(--transition);
  box-shadow: 0 2px 8px rgba(0,119,255,0.25);
  letter-spacing: 0.02em;
}
.btn-signin:hover { background: #0095f6; box-shadow: 0 4px 14px rgba(0,119,255,0.4); transform: translateY(-1px); }
.icon-btn {
  width: 36px; height: 36px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  color: var(--muted);
  transition: all var(--transition);
}
.icon-btn:hover { background: var(--paper-2); color: var(--ink); }

/* ===== MAIN LAYOUT ===== */
.main-wrapper {
  padding-top: 56px;
  max-width: 1200px;
  margin: 0 auto;
}

/* ===== CAROUSEL / HERO ===== */
.hero-section { padding: 24px 16px 0; }
@media(min-width:768px) { .hero-section { padding: 28px 0 0; } }
.carousel-wrapper {
  position: relative;
  height: 380px;
  border-radius: 16px;
  overflow: hidden;
  background: var(--paper-2);
}
@media(min-width:768px) { .carousel-wrapper { height: 460px; } }
#carousel-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  height: 100%; width: 100%;
  scrollbar-width: none;
}
#carousel-track::-webkit-scrollbar { display: none; }
.carousel-slide {
  flex: 0 0 100%;
  scroll-snap-align: center;
  position: relative;
  cursor: pointer;
}
.carousel-slide img {
  width: 100%; height: 100%;
  object-fit: cover;
}
.carousel-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(5,5,10,0.92) 0%, rgba(5,5,10,0.35) 55%, transparent 100%);
}
.carousel-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 24px 28px 28px;
  color: white;
}
.carousel-category {
  display: inline-block;
  background: linear-gradient(135deg, #0077ff, #0040dd);
  color: white;
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 4px;
  margin-bottom: 12px;
}
.carousel-title {
  font-family: var(--font-display);
  font-size: clamp(18px, 4vw, 28px);
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 10px;
  text-shadow: 0 1px 8px rgba(0,0,0,0.5);
}
.carousel-meta {
  display: flex; align-items: center; gap: 14px;
  font-size: 12px; opacity: 0.75;
}
.carousel-nav {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  color: white;
  width: 40px; height: 40px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  transition: all var(--transition);
  z-index: 5;
}
.carousel-nav:hover { background: rgba(255,255,255,0.3); transform: translateY(-50%) scale(1.05); }
#prev-slide { left: 14px; }
#next-slide { right: 14px; }
.carousel-dots {
  position: absolute; bottom: 14px; right: 28px;
  display: flex; gap: 6px; z-index: 5;
}
.carousel-dot {
  width: 6px; height: 6px;
  border-radius: 99px;
  background: rgba(255,255,255,0.4);
  transition: all 0.3s;
  cursor: pointer;
}
.carousel-dot.active { width: 20px; background: white; }

/* ===== CATEGORY FILTER ===== */
.filter-section {
  padding: 20px 16px 0;
  overflow-x: auto;
  scrollbar-width: none;
  white-space: nowrap;
}
@media(min-width:768px) { .filter-section { padding: 20px 0 0; } }
.filter-section::-webkit-scrollbar { display: none; }
.filter-inner { display: inline-flex; gap: 8px; }
.cat-btn {
  padding: 8px 18px;
  border-radius: 99px;
  font-size: 13px; font-weight: 600;
  background: var(--paper-2);
  color: var(--muted);
  border: 1px solid var(--border);
  transition: all var(--transition);
  white-space: nowrap;
}
.cat-btn:hover { background: var(--paper); color: var(--ink); border-color: var(--ink); }
.cat-btn.active {
  background: linear-gradient(135deg, #0077ff, #0040dd);
  color: white;
  border-color: #0077ff;
}
html.dark .cat-btn.active { background: #0077ff; color: white; border-color: #0077ff; }

/* ===== NEWS SECTION ===== */
.news-section { padding: 24px 16px 0; }
@media(min-width:768px) { .news-section { padding: 28px 0 0; } }
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px;
}
.section-title-group { display: flex; align-items: center; gap: 14px; }
.section-accent-bar {
  width: 4px; height: 28px;
  background: linear-gradient(180deg, #0077ff, #0040dd);
  border-radius: 2px;
}
.section-title {
  font-family: var(--font-display);
  font-size: 22px; font-weight: 700;
  letter-spacing: -0.3px;
}
.section-count {
  font-size: 12px; font-weight: 600;
  color: var(--muted);
  font-family: var(--font-mono);
  background: var(--paper-2);
  border: 1px solid var(--border);
  padding: 3px 10px;
  border-radius: 99px;
}

/* ===== NEWS GRID ===== */
#news-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}
@media(min-width:640px) { #news-grid { grid-template-columns: repeat(2, 1fr); } }
@media(min-width:1024px) { #news-grid { grid-template-columns: repeat(3, 1fr); } }

/* First card is featured */
#news-grid .news-card:first-child {
  grid-column: 1 / -1;
}
@media(min-width:640px) {
  #news-grid .news-card:first-child { grid-column: span 2; }
}
@media(min-width:1024px) {
  #news-grid .news-card:first-child { grid-column: span 2; }
}

.news-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
  transition: all var(--transition);
  cursor: pointer;
  position: relative;
  display: flex;
  flex-direction: column;
}
.news-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
  border-color: transparent;
}
.news-card-img-wrapper {
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
  background: var(--paper-2);
  position: relative;
}
.news-card:first-child .news-card-img-wrapper {
  aspect-ratio: 21/9;
}
.news-card-img-wrapper img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
  opacity: 0;
  transition: opacity 0.4s ease, transform 0.5s ease;
}
.news-card-img-wrapper img.loaded { opacity: 1; }
.news-card:hover .news-card-img-wrapper img { transform: scale(1.04); }
.news-card-body { padding: 16px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
.news-card-category {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
}
.news-card-title {
  font-family: var(--font-display);
  font-size: 15px; font-weight: 700;
  line-height: 1.45;
  color: var(--ink);
  flex: 1;
}
.news-card:first-child .news-card-title { font-size: 20px; }
.news-card-meta {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px; color: var(--muted);
  margin-top: auto;
  padding-top: 10px;
  border-top: 1px solid var(--border);
}
.news-card-source {
  font-weight: 600;
  display: flex; align-items: center; gap: 5px;
}
.news-card-source::before {
  content: '';
  width: 16px; height: 16px;
  border-radius: 4px;
  background: var(--paper-2);
  display: inline-block;
}
.news-card-time { margin-left: auto; font-family: var(--font-mono); font-size: 11px; }
.news-card-badge {
  position: absolute;
  top: 12px; left: 12px;
  background: var(--accent);
  color: white;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.05em; text-transform: uppercase;
  padding: 3px 8px; border-radius: 4px;
}
.news-card-external {
  position: absolute; top: 12px; right: 12px;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4px);
  color: white;
  width: 28px; height: 28px;
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px;
  opacity: 0;
  transition: opacity var(--transition);
}
.news-card:hover .news-card-external { opacity: 1; }

/* ===== SKELETON ===== */
@keyframes shimmer {
  0% { background-position: -600px 0; }
  100% { background-position: 600px 0; }
}
.skeleton {
  background: var(--paper-2);
  background-image: linear-gradient(90deg, var(--paper-2) 0%, var(--border) 40px, var(--paper-2) 80px);
  background-size: 600px 100%;
  animation: shimmer 1.6s infinite linear;
  border-radius: var(--r-sm);
}

/* ===== LOAD MORE ===== */
.load-more-wrapper { text-align: center; padding: 36px 0 20px; }
.btn-load-more {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 32px;
  border: 1.5px solid var(--border);
  border-radius: 99px;
  font-size: 14px; font-weight: 700;
  background: var(--card-bg);
  transition: all var(--transition);
  letter-spacing: 0.02em;
}
.btn-load-more:hover {
  background: linear-gradient(135deg, #0077ff, #0040dd); color: white;
  border-color: #0077ff;
  box-shadow: var(--shadow-md);
}
.btn-load-more.loading { opacity: 0.6; pointer-events: none; }

/* ===== COMMUNITY VIEW ===== */
#view-community { max-width: 600px; margin: 0 auto; }

/* ===== COMMUNITY TABS ===== */
.comm-tabs {
  display: flex;
  position: sticky; top: 56px;
  background: var(--paper);
  z-index: 30;
  border-bottom: 1px solid var(--border);
}
.comm-tab {
  flex: 1;
  padding: 13px;
  font-size: 13px; font-weight: 600;
  color: var(--muted);
  text-align: center;
  border-bottom: 2px solid transparent;
  transition: all var(--transition);
}
.comm-tab.active { color: #0077ff; border-bottom-color: #0077ff; }

/* ===== POST CARD ===== */
.post-card {
  background: var(--card-bg);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  margin-bottom: 16px;
  overflow: hidden;
}
@media(min-width:768px) {
  .post-card { border: 1px solid var(--border); border-radius: var(--r); }
}
.post-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 14px;
}
.post-author { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.post-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--border);
}
.post-name { font-size: 14px; font-weight: 700; }
.post-time { font-size: 11px; color: var(--muted); font-family: var(--font-mono); }
.post-image-wrapper {
  width: 100%;
  background: var(--paper-2);
  position: relative;
}
.post-image-wrapper img {
  width: 100%;
  max-height: 500px;
  object-fit: contain;
  display: block;
}
.post-actions {
  display: flex; align-items: center; gap: 16px;
  padding: 12px 14px 4px;
  font-size: 20px;
}
.action-btn {
  display: flex; align-items: center; gap: 6px;
  font-size: 20px;
  color: var(--ink);
  transition: all 0.15s;
}
.action-btn:hover { color: var(--accent); transform: scale(1.1); }
.action-btn.liked { color: var(--accent); }
.action-btn.bookmarked { color: var(--gold); }
.action-btn span { font-size: 13px; font-weight: 700; color: var(--ink); }
.post-footer { padding: 4px 14px 14px; }
.post-likes { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
.post-caption { font-size: 14px; line-height: 1.5; }
.post-caption .mention { color: var(--blue-soft); font-weight: 600; }
.post-caption .hashtag { color: var(--blue-soft); }
.post-view-comments { font-size: 13px; color: var(--muted); cursor: pointer; margin-top: 4px; }

/* ===== STORIES ===== */
.stories-wrapper {
  display: flex; gap: 14px;
  overflow-x: auto; padding: 16px;
  scrollbar-width: none;
  border-bottom: 1px solid var(--border);
  background: var(--card-bg);
  margin-bottom: 16px;
}
.stories-wrapper::-webkit-scrollbar { display: none; }
.story-item {
  display: flex; flex-direction: column; align-items: center; gap: 5px;
  cursor: pointer; flex-shrink: 0;
}
.story-ring {
  padding: 2.5px;
  border-radius: 50%;
  background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
  display: inline-block;
}
.story-ring.seen { background: var(--border); }
.story-avatar {
  width: 56px; height: 56px;
  border-radius: 50%;
  border: 2.5px solid var(--paper);
  object-fit: cover;
}
.story-add-btn {
  width: 56px; height: 56px;
  border-radius: 50%;
  border: 2px dashed var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; color: var(--muted);
  transition: all var(--transition);
}
.story-add-btn:hover { border-color: var(--accent); color: var(--accent); }
.story-label { font-size: 11px; font-weight: 600; color: var(--ink); max-width: 64px; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ===== BOTTOM NAV ===== */
.bottom-nav {
  display: flex;
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--card-bg);
  border-top: 1px solid var(--border);
  z-index: 100;
  padding: 8px 0 env(safe-area-inset-bottom, 0px);
}
@media(min-width:768px) { .bottom-nav { display: none; } }
.bottom-nav-btn {
  flex: 1;
  display: flex; flex-direction: column; align-items: center;
  padding: 6px 0;
  font-size: 22px;
  color: var(--muted);
  transition: color var(--transition);
  position: relative;
}
.bottom-nav-btn.active { color: var(--ink); }
.bottom-nav-btn:hover { color: var(--ink); }

/* ===== PAGE LAYERS ===== */
.page-layer {
  position: fixed; inset: 0;
  background: var(--paper);
  z-index: 200;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(.25,1,.5,1);
  overflow-y: auto;
  overscroll-behavior: contain;
}
.page-layer.open { transform: translateX(0); }
.modal-layer {
  position: fixed; inset: 0;
  background: var(--paper);
  z-index: 200;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(.25,1,.5,1);
  overflow-y: auto;
  overscroll-behavior: contain;
  display: flex; flex-direction: column;
}
.modal-layer.open { transform: translateY(0); }
.overlay-bg {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.65);
  z-index: 300;
  display: none;
  align-items: center; justify-content: center;
}
.overlay-bg.open { display: flex; }
.overlay-box {
  background: var(--card-bg);
  border-radius: 20px;
  padding: 32px;
  width: 90%; max-width: 400px;
  box-shadow: var(--shadow-lg);
  animation: popIn 0.25s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes popIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }

/* ===== AUTH MODAL ===== */
.auth-input {
  width: 100%; padding: 13px 16px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: var(--paper);
  font-size: 15px;
  outline: none; transition: all var(--transition);
  color: var(--ink);
}
.auth-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,119,255,0.1); }
.auth-submit {
  width: 100%; padding: 14px;
  background: linear-gradient(135deg, #0077ff, #0040dd);
  color: white;
  border-radius: 10px;
  font-size: 16px; font-weight: 700;
  transition: all var(--transition);
}
.auth-submit:hover { background: #0095f6; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,119,255,0.3); }
.auth-divider {
  display: flex; align-items: center; gap: 12px;
  color: var(--muted); font-size: 12px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.05em;
  margin: 20px 0;
}
.auth-divider::before, .auth-divider::after { content: ''; flex: 1; border-top: 1px solid var(--border); }
.auth-google-btn {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  width: 100%; padding: 13px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  font-size: 15px; font-weight: 700;
