@keyframes heartPop { 0%{transform:scale(1)} 50%{transform:scale(1.4)} 100%{transform:scale(1)} }
.heart-pop { animation: heartPop 0.3s ease; }

/* ===== DARK MODE OVERRIDES ===== */
html.dark .news-card-source::before { background: var(--paper-2); }
html.dark .auth-google-btn { border-color: var(--border); }

/* ===== LOADING STATE ===== */
.loading-overlay {
  position: fixed; inset: 0;
  background: var(--paper);
  z-index: 9999;
