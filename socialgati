async function loadCommunityFeed(reset = true) {
  if (reset) {
    lastCommunityDoc = null;
    if (communityUnsub) communityUnsub();
  }
  
  const feed = document.getElementById('community-feed');
  if (reset) {
    feed.innerHTML = renderPostSkeleton();
  }
  
  try {
    let q = query(
      collection(db, 'artifacts', APP_ID, 'public', 'data', 'reposts'),
      orderBy('timestamp', 'desc'),
      limit(10)
    );
    if (lastCommunityDoc) q = query(q, startAfter(lastCommunityDoc));
    
    const snap = await getDocs(q);
    if (reset) feed.innerHTML = '';
    
    if (snap.empty && reset) {
      feed.innerHTML = `<div style="text-align:center;padding:60px 20px;color:var(--muted)"><i class="fas fa-users" style="font-size:32px;margin-bottom:12px;display:block"></i><p style="font-weight:700">No posts yet</p><p style="font-size:13px;margin-top:6px">Be the first to post!</p></div>`;
      return;
    }
    
    snap.docs.forEach(d => {
      const el = document.createElement('div');
      el.innerHTML = renderPostCard(d.data(), d.id);
      feed.appendChild(el.firstElementChild);
    });
    
    lastCommunityDoc = snap.docs[snap.docs.length - 1];
  } catch(e) {
    console.error(e);
    if (reset) feed.innerHTML = `<div style="text-align:center;padding:40px 20px;color:var(--muted)">Could not load posts</div>`;
  }
}

function renderPostSkeleton() {
  return `<div class="post-card"><div style="padding:14px;display:flex;gap:10px;align-items:center"><div class="skeleton" style="width:36px;height:36px;border-radius:50%"></div><div style="flex:1"><div class="skeleton" style="height:12px;width:35%;margin-bottom:6px"></div><div class="skeleton" style="height:10px;width:20%"></div></div></div><div class="skeleton" style="width:100%;height:320px"></div><div style="padding:12px"><div class="skeleton" style="height:12px;width:60%;margin-bottom:8px"></div></div></div>`;
}

function renderPostCard(p, id) {
  const likes = p.likes || [];
  const isLiked = currentUser && likes.includes(currentUser.uid);
  const isBookmarked = userSavedPosts.includes(id);
  const av = p.userAvatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(p.username||'U')}&background=random`;
  
  let contentHTML = '';
  if (p.type === 'poll') {
    contentHTML = renderPollInCard(p, id);
  } else if (p.image) {
    contentHTML = `<div class="post-image-wrapper" ondblclick="toggleLike('${id}',true)"><img src="${p.image}" loading="lazy" alt="post" onerror="this.parentElement.style.display='none'"></div>`;
  }
  
  return `
    <div class="post-card fade-up" id="post-${id}">
      <div class="post-header">
        <div class="post-author" onclick="openPublicProfile('${p.userId||''}')">
          <img src="${av}" class="post-avatar" onerror="this.src='https://ui-avatars.com/api/?name=U&background=efefef'">
          <div>
            <div class="post-name">${p.username || 'User'}</div>
            <div class="post-time">${formatTimestamp(p.timestamp)}</div>
          </div>
        </div>
        <button onclick="showPostMenu('${id}','${p.userId||''}')" class="icon-btn"><i class="fas fa-ellipsis-h"></i></button>
      </div>
      ${contentHTML}
      <div class="post-actions">
        <button id="like-btn-${id}" class="action-btn ${isLiked?'liked':''}" onclick="toggleLike('${id}')">
          <i class="${isLiked?'fas':'far'} fa-heart"></i>
          <span id="like-count-${id}">${likes.length}</span>
        </button>
        <button class="action-btn" onclick="openComments('${id}')"><i class="far fa-comment"></i></button>
        <button class="action-btn" onclick="sharePost('${p.username||'User'}','${id}')"><i class="far fa-paper-plane"></i></button>
        <button id="bookmark-btn-${id}" class="action-btn ${isBookmarked?'bookmarked':''}" onclick="toggleBookmark('${id}')" style="margin-left:auto">
          <i class="${isBookmarked?'fas':'far'} fa-bookmark"></i>
        </button>
      </div>
      <div class="post-footer">
        <div class="post-likes">${likes.length} like${likes.length!==1?'s':''}</div>
        ${p.headline ? `<div class="post-caption"><span class="post-name">${p.username||'User'}</span> ${processText(p.headline)}</div>` : ''}
        ${(p.commentsCount||0) > 0 ? `<div class="post-view-comments" onclick="openComments('${id}')">View all ${p.commentsCount} comment${p.commentsCount!==1?'s':''}</div>` : ''}
      </div>
    </div>`;
}

function renderPollInCard(p, id) {
  const opts = p.pollOptions || [];
  const total = opts.reduce((s, o) => s + (o.votes || 0), 0);
  return `<div style="padding:14px 14px 0">
    ${opts.map((o, i) => `
      <div class="poll-option" onclick="votePoll('${id}',${i})">
        <div class="poll-bar" style="width:${total?Math.round((o.votes||0)/total*100):0}%"></div>
        <span class="poll-label">${o.text}</span>
        <span class="poll-pct">${total?Math.round((o.votes||0)/total*100):0}%</span>
      </div>`).join('')}
    <p style="font-size:12px;color:var(--muted);margin-top:8px;margin-bottom:4px">${total} vote${total!==1?'s':''}</p>
  </div>`;
}

